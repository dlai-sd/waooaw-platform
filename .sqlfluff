[sqlfluff]
templater = raw
dialect = postgres
max_line_length = 120
indent_unit = space
tab_space_size = 4

[sqlfluff:rules]
# Constitutional basis: C-072 (Coding Standards — SQL rules)
# All keywords uppercase (AM04, AM06)
# All identifiers lowercase (CP02, CP03)
# Explicit column lists — no SELECT * (ST06)

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:layout.indent]
indent_unit = space
tab_space_size = 4

[sqlfluff:rules:references.from]
# Always use table aliases consistently
force_enable = true

[sqlfluff:rules:structure.using_join]
# Prefer explicit JOIN ON over USING (clearer for multi-tenant joins)
force_enable = true

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

[sqlfluff:indentation]
allow_implicit_indents = false

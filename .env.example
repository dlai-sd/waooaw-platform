# WAOOAW Platform — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# Temporal uses a separate DB user in QA/prod.
# In dev, this defaults to POSTGRES_PASSWORD if not set.
TEMPORAL_DB_PASSWORD=change-me-temporal-db

# ─── Keycloak ──────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin
KEYCLOAK_CLIENT_SECRET=change-me-client-secret

# Google OAuth (only needed for testing real social login)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Dev Test User (for local development + integration tests) ─────────────
# Used to obtain a JWT token without Google OAuth.
# Keycloak realm includes a 'waooaw-dev-client' for direct access grants.
# Get a token: scripts/get-dev-token.sh
DEV_TEST_USER=dev@waooaw.local
DEV_TEST_PASSWORD=change-me-dev-password

# ─── LLM Provider ──────────────────────────────────────────────────────────
# Options: openai | azure-openai
LLM_PROVIDER=openai
LLM_API_KEY=change-me-llm-api-key
LLM_MODEL=gpt-4o-mini

# Azure OpenAI (only needed if LLM_PROVIDER=azure-openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ─── Temporal (cloud environments only — dev uses self-hosted) ─────────────
# TEMPORAL_CLOUD_NAMESPACE=waooaw-uat.tmprl.cloud:7233
# TEMPORAL_CLOUD_CERT_PATH=/secrets/temporal-client.pem
# TEMPORAL_CLOUD_KEY_PATH=/secrets/temporal-client.key

# ─── GHCR (for pulling images in cloud environments) ──────────────────────
# GHCR_PAT=change-me-github-pat-with-read-packages

# ─── LLM Provider ──────────────────────────────────────────────────────────
# Options: openai | azure-openai
LLM_PROVIDER=openai
LLM_API_KEY=change-me-llm-api-key
LLM_MODEL=gpt-4o-mini

# Azure OpenAI (only needed if LLM_PROVIDER=azure-openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ─── Temporal (cloud environments only — dev uses self-hosted) ─────────────
# TEMPORAL_CLOUD_NAMESPACE=waooaw-uat.tmprl.cloud:7233
# TEMPORAL_CLOUD_CERT_PATH=/secrets/temporal-client.pem
# TEMPORAL_CLOUD_KEY_PATH=/secrets/temporal-client.key

# ─── GHCR (for pulling images in cloud environments) ──────────────────────
# GHCR_PAT=change-me-github-pat-with-read-packages

# WAOOAW Platform — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ─── Keycloak ──────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin
KEYCLOAK_CLIENT_SECRET=change-me-client-secret

# ─── LLM Provider ──────────────────────────────────────────────────────────
# Options: openai | azure-openai
LLM_PROVIDER=openai
LLM_API_KEY=change-me-llm-api-key
LLM_MODEL=gpt-4o-mini

# Azure OpenAI (only needed if LLM_PROVIDER=azure-openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ─── Temporal (cloud environments only — dev uses self-hosted) ─────────────
# TEMPORAL_CLOUD_NAMESPACE=waooaw-uat.tmprl.cloud:7233
# TEMPORAL_CLOUD_CERT_PATH=/secrets/temporal-client.pem
# TEMPORAL_CLOUD_KEY_PATH=/secrets/temporal-client.key

# ─── GHCR (for pulling images in cloud environments) ──────────────────────
# GHCR_PAT=change-me-github-pat-with-read-packages

# WAOOAW Platform — .gitignore
# Secrets, build outputs, environment-specific files

# ─── Terraform secrets (NEVER commit) ────────────────────────────────────────
infrastructure/terraform/**/*.tfvars
infrastructure/terraform/**/.terraform/
infrastructure/terraform/**/.terraform.lock.hcl
infrastructure/terraform/**/terraform.tfstate
infrastructure/terraform/**/terraform.tfstate.backup
infrastructure/terraform/**/*.tfplan

# ─── Environment secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
infrastructure/postgres/pgbouncer/userlist.txt   # contains DB passwords

# ─── Build outputs ────────────────────────────────────────────────────────────
**/bin/
**/obj/
**/__pycache__/
**/*.pyc
**/*.pyo
node_modules/
.next/
out/
dist/
coverage/
*.trx
*.xml

# ─── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.vscode/settings.json
.idea/

# ─── CI artefacts ─────────────────────────────────────────────────────────────
.ci-evidence.log
.deployment-evidence.log
.rollback-evidence.log

# ─── FinOps sprint context (ephemeral — regenerated each autonomous sprint run) ─
.copilotignore                      # Auto-generated by build_sprint_index.py — not persistent
sprint-context/index.json           # Committed to branch during sprint, not to main
*.tar.gz
google-cloud-cli*
sprint-context/index.json
sprint-context/monitor-signal.json

root = true

# ─── Universal ──────────────────────────────────────────────────────────────
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ─── TypeScript / JavaScript / JSON ─────────────────────────────────────────
[*.{ts,tsx,js,jsx,json,jsonc}]
indent_size = 2

# ─── YAML ───────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─── HTML / Markdown ────────────────────────────────────────────────────────
[*.{html,md,mdx}]
indent_size = 2
trim_trailing_whitespace = false   # Markdown uses trailing spaces for line breaks

# ─── C# ─────────────────────────────────────────────────────────────────────
[*.cs]
indent_size = 4
# CSharpier handles all C# formatting — .editorconfig is supplementary here

# ─── SQL ────────────────────────────────────────────────────────────────────
[*.sql]
indent_size = 4

# ─── Proto ──────────────────────────────────────────────────────────────────
[*.proto]
indent_size = 2

# ─── Makefile (tabs required) ────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ─── Shell scripts ───────────────────────────────────────────────────────────
[*.sh]
indent_size = 2
